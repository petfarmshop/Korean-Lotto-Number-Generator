<!DOCTYPE html><html lang='ko'><head><meta charset='UTF-8'><meta name='viewport' content='width=device-width,initial-scale=1.0'><style>:root{--brand-main:#ff6b6b;--brand-sub:#fff5f0}body{font-family:sans-serif;background:var(--brand-sub);margin:0;padding:0;text-align:center;height:auto;overflow:hidden}.container{background:white;padding:20px;border-radius:30px;border:2px solid:#ffede5;display:inline-block;width:95%;max-width:380px;box-shadow:0 10px 30px rgba(0,0,0,0.05);box-sizing:border-box;margin-bottom:10px}.brand-logo{color:var(--brand-main);font-weight:900;font-size:1.6rem;margin-bottom:5px}.info-panel{font-size:0.85rem;color:#666;background:#f8f9fa;padding:12px;border-radius:18px;margin-bottom:15px;border:1px solid:#eee;line-height:1.4}.btn-generate{background:var(--brand-main);color:white;border:none;padding:15px;border-radius:15px;cursor:pointer;font-size:1rem;font-weight:bold;width:100%}.btn-save{background:#4caf50;color:white;border:none;padding:12px;border-radius:15px;cursor:pointer;font-size:0.9rem;font-weight:bold;width:100%;margin-top:10px;display:none}.set-box{background:#fffcfb;padding:10px 5px;border-radius:20px;margin-top:12px;border:1px solid:#ffe5db;white-space:nowrap}.ball-container{display:block;text-align:center;margin-top:5px;width:100%}.ball{display:inline-block!important;width:30px;height:30px;line-height:30px;margin:0 2px;border-radius:50%;color:white;font-weight:bold;font-size:0.75rem;text-align:center;box-shadow:inset -2px -2px 4px rgba(0,0,0,0.1);vertical-align:middle}.small-ball{width:22px!important;height:22px!important;line-height:22px!important;font-size:0.6rem!important;margin:0 1px!important}.n-y{background:#ffbc00}.n-b{background:#4d94ff}.n-r{background:#ff5c5c}.n-g{background:#94a3b8}.n-v{background:#8bc34a}.bonus-plus{display:inline-block;font-size:0.8rem;font-weight:bold;color:#ff8e8e;margin:0 2px;vertical-align:middle}.notice-title{font-size:0.95rem;color:#ff6b6b;font-weight:bold;margin-top:15px;display:block}.notice-desc{font-size:0.72rem;color:#999;margin:5px 0 8px 0;line-height:1.4}.last-result-label{font-size:0.68rem;color:#ff8e8e;font-weight:bold;margin-bottom:4px;display:block}#previewOverlay{display:none;position:fixed;top:0;left:0;width:100%;height:100%;background:rgba(0,0,0,0.85);z-index:9999;flex-direction:column;align-items:center;justify-content:center;padding:15px;box-sizing:border-box}#previewImg{max-width:85%;max-height:80%;border-radius:20px;box-shadow:0 0 20px rgba(255,255,255,0.3);margin-bottom:12px}#previewClose{margin-top:10px;color:white;background:#666;padding:8px 25px;border-radius:20px;font-size:0.9rem;cursor:pointer}</style><script src='https://html2canvas.hertzen.com/dist/html2canvas.min.js'></script></head><body><div id='previewOverlay'><img id='previewImg' src=''><p style='color:white;font-size:0.85rem;margin:0;line-height:1.4;word-break:keep-all;'>이 이미지를 마우스 우측 클릭해<br>저장 후 공유하세요!</p><div id='previewClose' onclick='closePreview()'>닫기</div></div><div class='container' id='captureArea'><div class='brand-logo'>멍냥쿡꾸 &#128242;</div><div id='infoPanel' class='info-panel'>제 1214회 데이터 분석 완료!<br>최신 행운 번호를 생성합니다.</div><button id='genBtn' class='btn-generate' onclick='startAnalysis()'>행운 번호 받기</button><div id='lastWinSection'></div><div id='results'></div></div><button id='saveBtn' class='btn-save' onclick='saveImage()'>📸 이미지로 저장 & 공유하기</button><script>function sendHeight(){setTimeout(function(){var h=document.body.scrollHeight+50;window.parent.postMessage({lottoHeight:h},'*')},100)}var lastWinNums=['10','15','19','27','30','33'];var bonusNum='14';var lastRound=1214;function startAnalysis(){const results=document.getElementById('results');results.innerHTML='<p style=\x22color:#ff6b6b;font-size:0.85rem;margin-top:15px;\'>조합 분석 중...</p>';sendHeight();setTimeout(function(){const balls=lastWinNums.map(n=>{const c=n<=10?'n-y':n<=20?'n-b':n<=30?'n-r':n<=40?'n-g':'n-v';return `<div class='ball small-ball ${c}'>${n}</div>`}).join('');const bc=bonusNum<=10?'n-y':bonusNum<=20?'n-b':bonusNum<=30?'n-r':bonusNum<=40?'n-g':'n-v';document.getElementById('lastWinSection').innerHTML=`<div class='set-box' style='background:#fffafa;padding:8px 5px;border:none;'><span class='last-result-label'>&#128203; 지난 ${lastRound}회 당첨 번호</span><div class='ball-container'>${balls}<span class='bonus-plus'>+</span><div class='ball small-ball ${bc}'>${bonusNum}</div></div></div>`;results.innerHTML='<span class=\x22notice-title\x22>&#10024; 이번 주의 행운번호</span><p class=\x22notice-desc\x22>이 번호는 데이터에 의해 생성된 것으로 당첨 보장은 없습니다.</p>';for(let s=1;s<=2;s++){let nums=[];while(nums.length<6){let n=Math.floor(Math.random()*45)+1;if(!nums.includes(n))nums.push(n)}nums.sort((a,b)=>a-b);const setBox=document.createElement('div');setBox.className='set-box';const ballHtml=nums.map(n=>{const c=n<=10?'n-y':n<=20?'n-b':n<=30?'n-r':n<=40?'n-g':'n-v';return `<div class='ball ${c}'>${n}</div>`}).join('');setBox.innerHTML=`<span style='font-size:0.75rem;color:#ff8e8e;font-weight:bold;'>#행운세트_${s}</span><div class='ball-container'>${ballHtml}</div>`;results.appendChild(setBox)}document.getElementById('saveBtn').style.display='block';sendHeight()},600)}function saveImage(){const area=document.getElementById('captureArea');html2canvas(area,{backgroundColor:'#fff5f0',borderRadius:30,scale:1.5}).then(canvas=>{const dataUrl=canvas.toDataURL('image/png');document.getElementById('previewImg').src=dataUrl;document.getElementById('previewOverlay').style.display='flex';})}function closePreview(){document.getElementById('previewOverlay').style.display='none';}window.onload=sendHeight;</script></body></html>" style="width:100%;border:none;min-height:600px;display:block;overflow:hidden;" sandbox="allow-scripts allow-same-origin">
